{
  "entities": {
    "KitItem": {
      "title": "Kit ou Item de Decoração",
      "description": "Armazena os kits e itens de decoração exibidos no site público.",
      "type": "object",
      "properties": {
        "codigo_produto": { "type": "string", "description": "Código único do produto" },
        "titulo": { "type": "string", "description": "Título do kit/item" },
        "descricao": { "type": "string", "description": "Descrição detalhada" },
        "tipo": { "type": "string", "enum": ["kit_completo", "item_avulso", "painel", "mesa", "baloes", "outros"] },
        "tema": { "type": "string" },
        "preco_locacao": { "type": "number" },
        "cores": { "type": "array", "items": { "type": "string" } },
        "dimensoes": { "type": "string" },
        "itens_inclusos": { "type": "string" },
        "imagens": { "type": "array", "items": { "type": "string" } },
        "capa_url": { "type": "string" },
        "url_publica": { "type": "string" },
        "destaque": { "type": "boolean" },
        "publicado": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["codigo_produto", "titulo", "tipo", "preco_locacao"]
    },
    "ApiKey": {
      "title": "Chave de API",
      "description": "Representa uma credencial de acesso à API.",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "name": { "type": "string" },
        "active": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" },
        "last_used": { "type": "string", "format": "date-time" }
      },
      "required": ["key", "name", "active"]
    },
    "AiConfig": {
      "title": "Configuração de IA",
      "description": "Armazena o provedor e modelo padrão de IA.",
      "type": "object",
      "properties": {
        "provider": { "type": "string", "enum": ["gemini", "openai"] },
        "model": { "type": "string" },
        "api_key": { "type": "string" },
        "default_mode": { "type": "string", "enum": ["enxuto", "detalhado"] }
      }
    },
    "AiSearchLog": {
      "title": "Log de Busca IA",
      "description": "Registro de consulta e interpretação da IA.",
      "type": "object",
      "properties": {
        "query": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "filters": { "type": "object" },
        "result_count": { "type": "number" },
        "status": { "type": "string" },
        "duration_ms": { "type": "number" }
      }
    },
    "SiteConfig": {
      "title": "Configuração do Site",
      "description": "Armazena os dados institucionais e configurações globais do site.",
      "type": "object",
      "properties": {
        "nome_empresa": { "type": "string" },
        "logo_url": { "type": "string" },
        "favicon_url": { "type": "string" },
        "endereco_texto": { "type": "string" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "google_maps_url": { "type": "string" },
        "politica_privacidade": { "type": "string" },
        "termos_uso": { "type": "string" },
        "politica_cookies": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "kits_e_itens": {
      "schema": "KitItem",
      "description": "Coleção de kits e itens de decoração."
    },
    "config_site": {
      "schema": "SiteConfig",
      "description": "Documento único de configuração do site (id: 'global')."
    },
    "api_keys": {
      "schema": "ApiKey",
      "description": "Coleção de chaves de acesso para a API REST privada."
    },
    "ai_config": {
      "schema": "AiConfig",
      "description": "Documento único de configuração de IA (id: 'global')."
    },
    "ai_search_logs": {
      "schema": "AiSearchLog",
      "description": "Logs de auditoria das buscas realizadas via IA."
    }
  }
}
