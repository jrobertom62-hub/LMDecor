rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for KitItem
    function isValidKitItem(data) {
      return data.codigo_produto is string && data.codigo_produto.size() <= 50
        && data.titulo is string && data.titulo.size() <= 200
        && data.preco_locacao is number
        && data.tipo in ['kit_completo', 'item_avulso', 'painel', 'mesa', 'baloes', 'outros']
        && (data.capa_url == null || (data.capa_url is string && data.capa_url.size() <= 1000));
    }

    match /kits_e_itens/{itemId} {
      allow read: if true; // Public listings
      allow create, update: if isValidKitItem(incoming()); 
      allow delete: if true; // No auth phase
    }

    // Validation for SiteConfig
    function isValidSiteConfig(data) {
      return data.nome_empresa is string && data.nome_empresa.size() <= 100
        && (data.email == null || (data.email is string && data.email.size() <= 255));
    }

    match /config_site/{configId} {
      allow read: if true;
      allow write: if isValidSiteConfig(incoming());
    }
  }
}
